{% comment %}
  Product Reviews App Block
  Displays customer reviews for the current product using metafields
{% endcomment %}

<div class="product-reviews-block" data-product-id="{{ product.id }}">
  <h3 class="reviews-heading">{{ block.settings.heading }}</h3>

  <div class="reviews-summary">
    <div class="average-rating">
      {% assign total_rating = 0 %}
      {% assign review_count = 0 %}
      
      {% comment %} Check if product has rating metafield {% endcomment %}
      {% if product.metafields.custom.rating.value != blank %}
        {% assign total_rating = product.metafields.custom.rating.value | times: 1 %}
        {% assign review_count = 1 %}
      {% endif %}

      {% if review_count > 0 %}
        {% assign average = total_rating | divided_by: review_count %}
        <span class="rating-stars" style="color: {{ block.settings.star_color }};">
          {% assign full_stars = average | floor %}
          {% for i in (1..5) %}
            {% if i <= full_stars %}
              ★
            {% else %}
              ☆
            {% endif %}
          {% endfor %}
        </span>
        <span class="review-count">({{ product.metafields.custom.rating.value }} out of 5)</span>
      {% else %}
        <span class="no-reviews">No reviews yet</span>
      {% endif %}
    </div>
  </div>

  {% if block.settings.show_material_info and product.metafields.custom.material.value != blank %}
    <div class="product-material">
      <h4>Material</h4>
      <p>{{ product.metafields.custom.material.value }}</p>
    </div>
  {% endif %}

  {% if block.settings.show_care_instructions and product.metafields.custom.care_instructions.value != blank %}
    <div class="product-care">
      <h4>Care Instructions</h4>
      <p>{{ product.metafields.custom.care_instructions.value }}</p>
    </div>
  {% endif %}

  {% if block.settings.show_author_info %}
    {% assign author = product.metafields.custom.author.metaobject %}
    {% if author %}
      <div class="product-author">
        <h4>Designed by</h4>
        <div class="author-info">
          {% if author.fields.avatar.value != blank %}
            {{ author.fields.avatar.value | image_url: width: 100 | image_tag: class: "author-avatar", alt: author.fields.name.value }}
          {% endif %}
          <div class="author-details">
            <p class="author-name">{{ author.fields.name.value }}</p>
            {% if author.fields.bio.value != blank %}
              <p class="author-bio">{{ author.fields.bio.value }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  {% if block.settings.show_size_chart and product.metafields.custom.size_chart.metaobject != blank %}
    {% assign size_chart = product.metafields.custom.size_chart.metaobject %}
    {% if size_chart %}
      <div class="product-size-chart">
        <h4>{{ size_chart.fields.chart_name.value }}</h4>
        {% comment %} Size chart data is JSON stored as string - display as pre-formatted {% endcomment %}
        <pre class="size-chart-data">{{ size_chart.fields.chart_data.value }}</pre>
        <p class="size-chart-note">Size chart data is available via JavaScript for custom rendering</p>
      </div>
    {% endif %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Product Reviews",
  "target": "section",
  "stylesheet": "product-reviews.css",
  "javascript": "product-reviews.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Details"
    },
    {
      "type": "checkbox",
      "id": "show_material_info",
      "label": "Show material info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_care_instructions",
      "label": "Show care instructions",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author_info",
      "label": "Show author info (if linked)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_size_chart",
      "label": "Show size chart (if linked)",
      "default": false
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#FFD700"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
